# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://verus:verus_dev@localhost:5432/verus
DATABASE_URL_SYNC=postgresql://verus:verus_dev@localhost:5432/verus

# ── AI ────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...          # Optional — used for ada-002 embeddings

# ── AWS / S3 ──────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your-key-id
AWS_SECRET_ACCESS_KEY=your-secret
AWS_DEFAULT_REGION=us-east-1
S3_BUCKET_NAME=verus-documents-dev

# LocalStack override for local dev
# AWS_ENDPOINT_URL=http://localhost:4566

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-in-production-use-32-chars-minimum
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Application ───────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000

# ── Embeddings ────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=text-embedding-3-small   # openai | anthropic
EMBEDDING_DIMENSIONS=1536

# ── Ingestion Worker ──────────────────────────────────────────────────────────
INGESTION_POLL_INTERVAL_SECONDS=10
INGESTION_BATCH_SIZE=10
INGESTION_MAX_RETRIES=3

# CORS
CORS_ORIGINS=http://localhost:3000
